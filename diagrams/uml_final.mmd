classDiagram
    %% PawPal+ class design. Keep this file in sync with your Python implementation.

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~str~ special_care_needs
        +list~Task~ tasks
        +add_care_need(need str) None
        +add_task(task Task) None
        +task_count() int
        +describe() str
    }

    class Owner {
        +str name
        +dict preferences
        +int available_minutes
        +list~Pet~ pets
        +add_pet(pet Pet) None
        +set_availability(minutes int) None
        +get_available_minutes() int
    }

    class Task {
        +str title
        +int duration_minutes
        +Priority priority
        +str description
        +Pet pet
        +bool completed
        +str time
        +str date
        +str recurrence
        +int interval_minutes
        +int occurrences
        +mark_complete() None
        +is_recurring() bool
        +next_occurrence() Task
        +priority_score() int
        +describe() str
    }

    class ScheduledItem {
        +str start_time
        +Task task
        +start_minutes() int
        +end_minutes() int
        +end_time() str
        +overlaps(other ScheduledItem) bool
        +describe() str
    }

    class Conflict {
        +ScheduledItem first
        +ScheduledItem second
        +bool same_pet
        +describe() str
    }

    class Scheduler {
        +Owner owner
        +list~Task~ tasks
        +add_task(task Task) None
        +remove_task(task Task) None
        +complete_task(task Task) Task
        +sort_tasks() list~Task~
        +sort_tasks_by_time() list~Task~
        +sort_by_time(schedule list~ScheduledItem~)$ list~ScheduledItem~
        +filter_tasks(pet Pet, pet_name str, completed bool) list~Task~
        +generate_schedule(start_time str, include_completed bool) list~ScheduledItem~
        +find_conflicts(schedule list~ScheduledItem~) list~Conflict~
        +detect_conflicts(schedule list~ScheduledItem~) list
        +explain_conflicts(schedule list~ScheduledItem~) str
        +conflict_warning(schedule list~ScheduledItem~) str
        +explain() str
    }

    Owner "1" *-- "0..*" Pet : owns
    Pet "1" o-- "0..*" Task : has care task
    Scheduler "1" o-- "0..*" Task : manages
    Scheduler "1" --> "1" Owner : plans for
    Scheduler ..> ScheduledItem : produces
    Scheduler ..> Conflict : produces
    Task --> Priority : uses
    Task ..> Task : next_occurrence
    ScheduledItem --> Task : wraps
    ScheduledItem ..> ScheduledItem : overlaps
    Conflict "1" --> "2" ScheduledItem : pairs
